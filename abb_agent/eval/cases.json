    "must_not_include": ["SetDO doSprayOn"],
    "expect_category": "zigzag_scan"
  },
  {
    "id": "irc5p_arc",
    "query": "沿圆弧轨迹喷涂曲面，3 点定义圆弧",
    "controller": "IRC5P",
