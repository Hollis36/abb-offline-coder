    "controller": "IRC5",
    "must_include": ["MoveL", "SetDO"],
    "must_not_include": ["brushdata"],
    "expect_category": "zigzag_scan"
  },
  {
    "id": "irc5_arc",
    "query": "沿圆弧轨迹喷涂，3 点定义圆弧，速度 v200",
    "controller": "IRC5",
    "must_include": ["MoveC"],
    "must_not_include": ["brushdata"],
    "expect_category": "arc_scan"
  },
  {
    "id": "irc5p_line",
